<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Modern Express App</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo" style="margin: 0;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h2>Admin</h2>
            </div>
            
            <nav class="sidebar-nav">
                <li class="nav-item">
                    <a href="/admin/dashboard" class="nav-link active">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/admin/users" class="nav-link">
                        Users
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/admin/settings" class="nav-link">
                        Settings
                    </a>
                </li>
            </nav>

            <div class="footer" style="text-align: left; margin-top: auto;">
                <a href="/login" style="color: var(--error);">Sign out</a>
            </div>
        </aside>

        <main class="main-content">
            <header class="welcome-header">
                <h1>Welcome back, <%= users.length > 0 ? users[0].email : "Admin" %></h1>
                <p class="subtitle">Here's what's happening with your projects today.</p>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-header">Total Users</div>
                    <div class="stat-value">2,543</div>
                    <div class="stat-change positive">↑ 12% vs last month</div>
                </div>
                <div class="stat-card">
                    <div class="stat-header">Active Sessions</div>
                    <div class="stat-value">842</div>
                    <div class="stat-change positive">↑ 5% vs last hour</div>
                </div>
                <div class="stat-card">
                    <div class="stat-header">System Health</div>
                    <div class="stat-value">99.9%</div>
                    <div class="stat-change positive">Healthy</div>
                </div>
            </div>
            <% if (users.length > 0) { %>
            <div class="table-container">
                <div class="table-header">
                    <h3>Recent Activity</h3>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Action</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (let user of users) { %>
                        <tr>
                            <td><%= user.email %></td>
                            <td>Updated profile</td>
                            <td><span class="badge badge-success">Completed</span></td>
                            <td>2 mins ago</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </main>
    </div>
</body>
</html>
