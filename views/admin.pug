doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Admin Dashboard - Modern Express App
        link(rel="stylesheet", href="/style.css")
        link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap", rel="stylesheet")
    body
        div.dashboard-container
            aside.sidebar
                div.sidebar-header
                    div.logo(style="margin: 0;")
                        svg(viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2")
                            rect(x="3", y="11", width="18", height="11", rx="2", ry="2")
                            path(d="M7 11V7a5 5 0 0 1 10 0v4")
                    h2 Admin
                
                nav.sidebar-nav
                    li.nav-item
                        a.nav-link.active(href="/admin/dashboard") Dashboard
                    li.nav-item
                        a.nav-link(href="/admin/users") Users
                    li.nav-item
                        a.nav-link(href="/admin/settings") Settings

                div.footer(style="text-align: left; margin-top: auto;")
                    a(href="/login", style="color: var(--error);") Sign out

            main.main-content
                header.welcome-header
                    h1 Welcome back, #{users[0].email}
                    p.subtitle Here's what's happening with your projects today.

                div.stats-grid
                    div.stat-card
                        div.stat-header Total Users
                        div.stat-value 2,543
                        div.stat-change.positive ↑ 12% vs last month
                    div.stat-card
                        div.stat-header Active Sessions
                        div.stat-value 842
                        div.stat-change.positive ↑ 5% vs last hour
                    div.stat-card
                        div.stat-header System Health
                        div.stat-value 99.9%
                        div.stat-change.positive Healthy

                div.table-container
                    div.table-header
                        h3 Recent Activity
                    table
                        thead
                            tr
                                th User
                                th Action
                                th Status
                                th Date
                        tbody
                            tr
                                td Alex Johnson
                                td Updated profile
                                td: span.badge.badge-success Completed
                                td 2 mins ago
                            tr
                                td Maria Garcia
                                td New registration
                                td: span.badge.badge-success Completed
                                td 15 mins ago
                            tr
                                td David Smith
                                td Failed login attempt
                                td: span.badge.badge-warning Warning
                                td 1 hour ago
